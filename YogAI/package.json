{
  "name": "YogAI",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "android:gradle": ".\\android\\gradlew.bat -p android app:installDebug -PreactNativeDevServerPort=8081 --no-daemon",
    "android:gradle:emu": ".\\android\\gradlew.bat -p android app:installDebug -PreactNativeDevServerPort=8081 -PreactNativeArchitectures=x86_64 --no-daemon",
    "android:recover:emu": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\android-recover.ps1",
    "android:launch": "adb -s emulator-5554 shell monkey -p com.yogai -c android.intent.category.LAUNCHER 1",
    "android:adb:reset": "adb kill-server && adb start-server && adb devices -l",
    "android:emu:headless": "emulator -avd Medium_Phone -no-window -no-audio -no-snapshot-load -gpu swiftshader_indirect",
    "android:doctor": "npx react-native doctor",
    "android:healthcheck": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$ErrorActionPreference='Stop'; Write-Host 'Node:'; node -v; Write-Host 'npm:'; npm -v; Write-Host 'Java:'; java -version; Write-Host 'ADB:'; adb version; Write-Host 'Devices:'; adb devices -l; Write-Host 'Gradle:'; .\\android\\gradlew.bat -p android -v\"",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-native-firebase/app": "^23.8.8",
    "@react-native-firebase/auth": "^23.8.8",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-native/new-app-screen": "0.84.1",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.10",
    "@tanstack/react-query": "^5.95.2",
    "axios": "^1.14.0",
    "react": "19.2.3",
    "react-hook-form": "^7.72.0",
    "react-native": "0.84.1",
    "react-native-bootsplash": "^7.2.0",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-pager-view": "^8.0.0",
    "react-native-reanimated": "^4.3.0",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-toast-message": "^2.3.3",
    "react-native-vector-icons": "^10.3.0",
    "react-native-worklets": "^0.8.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "^20.1.3",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.84.1",
    "@react-native/eslint-config": "0.84.1",
    "@react-native/metro-config": "0.84.1",
    "@react-native/typescript-config": "0.84.1",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-native-vector-icons": "^6.4.18",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
